{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CamundaExamQuestion",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "topic",
    "difficulty",
    "style",
    "camundaVersion",
    "question",
    "options",
    "correctOptionId",
    "optionExplanations",
    "explanation",
    "docs"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(mod|cfg|dec|frm|con|ext|mng|dev)-[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Unique kebab-case id, prefixed by topic abbreviation."
    },
    "topic": {
      "type": "string",
      "enum": [
        "modeling",
        "configuring-processes",
        "decisions-business-rules",
        "forms",
        "connectors",
        "extensions-integrations",
        "managing-development",
        "dev-environment"
      ]
    },
    "subtopic": {
      "type": "string",
      "description": "Optional fine-grained category, e.g. 'subprocesses'."
    },
    "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
    "style": { "type": "string", "enum": ["scenario", "concept", "recall"] },
    "kind": {
      "type": "string",
      "enum": ["single", "negative"],
      "description": "Item kind. 'single' (default) is a standard 1-of-4. 'negative' asks for the wrong/false option; the stem must contain NOT or FALSE."
    },
    "camundaVersion": { "type": "string", "const": "8.8" },
    "scenario": {
      "type": "string",
      "maxLength": 800,
      "description": "Optional runtime situation; short tech-token framing (BPMN/FEEL snippets, ISO 8601, @JobWorker) preferred over fictional-company narrative."
    },
    "question": {
      "type": "string",
      "minLength": 20,
      "maxLength": 400,
      "pattern": "\\?\\s*$",
      "description": "Interrogative sentence ending with '?'. For kind=negative, must contain NOT or FALSE."
    },
    "options": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string", "enum": ["a", "b", "c", "d"] },
          "text": { "type": "string", "minLength": 1, "maxLength": 600 }
        }
      }
    },
    "correctOptionId": { "type": "string", "enum": ["a", "b", "c", "d"] },
    "optionExplanations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["a", "b", "c", "d"],
      "properties": {
        "a": { "$ref": "#/definitions/explanation" },
        "b": { "$ref": "#/definitions/explanation" },
        "c": { "$ref": "#/definitions/explanation" },
        "d": { "$ref": "#/definitions/explanation" }
      }
    },
    "explanation": { "type": "string", "minLength": 40, "maxLength": 800 },
    "docs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "url"],
        "properties": {
          "title": { "type": "string", "minLength": 4, "maxLength": 160 },
          "url": {
            "type": "string",
            "pattern": "^https://docs\\.camunda\\.io/docs/"
          }
        }
      }
    },
    "codeBlocks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stem": { "type": "string", "maxLength": 2000 },
        "perOption": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "a": { "type": "string", "maxLength": 1000 },
            "b": { "type": "string", "maxLength": 1000 },
            "c": { "type": "string", "maxLength": 1000 },
            "d": { "type": "string", "maxLength": 1000 }
          }
        }
      }
    },
    "diagramUrl": {
      "type": "string",
      "format": "uri",
      "description": "Optional URL of an inline BPMN/DMN diagram image."
    },
    "diagramAlt": {
      "type": "string",
      "maxLength": 300,
      "description": "Alt text for diagramUrl."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 20,
          "maxLength": 800
        },
        "verdict": { "type": "string", "maxLength": 80 },
        "score": { "type": "number", "minimum": 0, "maximum": 10 }
      }
    }
  }
}
