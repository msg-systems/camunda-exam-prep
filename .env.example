# Copy to .env.local (gitignored) and fill in the key(s) you need.
# Only required to run pipeline/rewrite-with-llm.mjs. The app itself has no
# server, no API calls, and reads no env vars at runtime.

# Anthropic (recommended; default provider for rewrite-with-llm.mjs).
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (optional; pass --provider openai to rewrite-with-llm.mjs).
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
