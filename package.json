{
  "name": "camunda-exam-prep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "questions:build": "node pipeline/build-pool.mjs",
    "gen:fetch": "node pipeline/generation/fetch-sources.mjs",
    "gen:plan": "node pipeline/generation/plan.mjs",
    "gen:prompts": "node pipeline/generation/build-prompts.mjs",
    "gen:batch": "node pipeline/generation/run-batch.mjs",
    "gen:lint": "node pipeline/generation/lint-outputs.mjs",
    "gen:critic:prompts": "node pipeline/generation/build-critic-prompts.mjs",
    "gen:critic:apply": "node pipeline/generation/apply-critic.mjs",
    "gen:promote": "node pipeline/import-regenerated.mjs --src=pipeline/generation/accepted --replace && node pipeline/build-pool.mjs --blueprint=pipeline/blueprint-600.json && node pipeline/curate-top.mjs --size=600 --min-score=55 --apply --blueprint=pipeline/blueprint-600.json"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
